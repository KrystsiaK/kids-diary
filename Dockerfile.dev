FROM node:22-bookworm-slim

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

COPY . .

# Client generation does not connect to PostgreSQL, but Prisma config requires a URL.
RUN DATABASE_URL="postgresql://postgres:postgres@database:5432/kids_diary?schema=public" npm run db:generate

EXPOSE 3000

CMD ["sh", "-c", "npm run db:migrate:deploy && npm run dev -- --hostname 0.0.0.0"]
